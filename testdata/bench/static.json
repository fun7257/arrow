    {"method": "GET", "pattern": "/api/v1/feeds", "response": "feeds"},
    {"method": "GET", "pattern": "/api/v1/notifications", "response": "notifications"},
    {"method": "GET", "pattern": "/api/v1/marketplace", "response": "marketplace"},
    {"method": "GET", "pattern": "/api/v1/meta", "response": "meta"},
